# .legionignore — patterns to skip during entity extraction
# Same syntax as .gitignore (https://git-scm.com/docs/gitignore)
# Independent of .gitignore — Legion does not auto-respect .gitignore.
#
# NOTE: Legion ALSO has a hardcoded list of always-on ignores (see
# IMPLICIT_IGNORE_PATTERNS in src/driver/legionignore.ts). The most
# critical paths (.cursor/, .claude/, .claude-plugin/, .legion/, library/,
# .env, *.key, secrets/, etc.) are protected even if you delete them
# from this file. The patterns below are best-practice opt-ins.

# Build outputs
node_modules/
dist/
build/
out/
.next/
.nuxt/
coverage/
.turbo/
.cache/

# Lock files
*.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Minified
*.min.js
*.min.css

# Python
.venv/
__pycache__/
*.pyc

# Editor / OS
.git/
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generated
*.generated.ts
*.generated.tsx
*.d.ts

# AI / agent tool folders (we own these — extracting them creates noise + recursion)
.cursor/
.cursor/agents/
.cursor/skills/
.cursor/rules/
.cursor/plugins/
.claude/
.claude-plugin/
.claude-plugin/agents/
.claude-plugin/skills/
.aider/
.continue/
.windsurf/
.codeium/
.tabnine/

# Secrets and environment files (never index)
.env
.env.*
.envrc
*.pem
*.key
secrets/
.secrets/

# CI / Cloud config (rarely useful as entities)
.github/
.gitlab/
.circleci/
.azure-pipelines/
.husky/

# Lockfiles + checksums for non-JS ecosystems
Gemfile.lock
Cargo.lock
composer.lock
poetry.lock
Pipfile.lock
go.sum

# Test / coverage artifacts
.nyc_output/
.pytest_cache/
.mypy_cache/
.tox/

# Legion's own state (don't recurse into the wiki itself)
.legion/
.legion-shared/
library/
bundled/
